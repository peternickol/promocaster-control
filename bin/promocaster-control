#!/usr/bin/env python3
import argparse
import json
import os
import shutil
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path


def read_env_file(path: Path) -> dict[str, str]:
    values: dict[str, str] = {}
    if not path.exists():
        return values
    for raw_line in path.read_text(encoding="utf-8").splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        values[key.strip()] = value.strip().strip('"').strip("'")
    return values


PLATTER_CONFIG_PATH = Path("/etc/platter/project/promocaster-control.env")
DEFAULT_CONFIG_PATH = PLATTER_CONFIG_PATH
CONFIG_PATH = Path(os.environ.get("PROMOCASTER_CONTROL_CONFIG_PATH", DEFAULT_CONFIG_PATH))
CONFIG_ENV = read_env_file(CONFIG_PATH)


def setting(name: str, default: str | Path) -> str:
    return os.environ.get(name) or CONFIG_ENV.get(name) or str(default)


APP_DIR = Path(setting("PROMOCASTER_CONTROL_APP_DIR", "/srv/platter/project/current"))
SOURCE_ROOT = Path(setting("PROMOCASTER_CONTROL_SOURCE_ROOT", "/root/repo/promocaster-control"))
CONFIG_DIR = Path(setting("PROMOCASTER_CONTROL_CONFIG_DIR", CONFIG_PATH.parent))
SOURCE_ROOT_FILE = Path(os.environ.get("PROMOCASTER_CONTROL_SOURCE_ROOT_FILE", CONFIG_DIR / "source-root"))
DATA_DIR = Path(setting("PROMOCASTER_CONTROL_DATA_DIR", "/var/lib/platter/project"))
SSH_DIR = Path(setting("PROMOCASTER_CONTROL_SSH_DIR", DATA_DIR / "ssh"))
CLIENT_GITHUB_KEY = Path(setting("PROMOCASTER_CONTROL_CLIENT_GITHUB_KEY", SSH_DIR / "client_github_key"))
REPOS_DIR = Path(setting("PROMOCASTER_CONTROL_REPOS_DIR", DATA_DIR / "client"))
UPLOADS_DIR = Path(setting("PROMOCASTER_CONTROL_UPLOADS_DIR", DATA_DIR / "uploads"))
SYNC_DIR = Path(setting("PROMOCASTER_CONTROL_SYNC_DIR", DATA_DIR / "sync"))
CONTROL_GIT_CONFIG = Path(setting("PROMOCASTER_CONTROL_GIT_CONFIG", DATA_DIR / "gitconfig"))
BUILD_DIR = Path(setting("PROMOCASTER_CONTROL_BUILD_DIR", "/tmp/promocaster-control-builds"))
SERVICE_USER = setting("PROMOCASTER_CONTROL_SERVICE_USER", "platter-project")
GLOBAL_BIN = Path(setting("PROMOCASTER_CONTROL_GLOBAL_BIN", "/usr/local/bin/promocaster-control"))
GIB = 1024**3
DATA_FREE_WARN_BYTES = int(os.environ.get("PROMOCASTER_CONTROL_DATA_FREE_WARN_GB", "20")) * GIB
DATA_FREE_FAIL_BYTES = int(os.environ.get("PROMOCASTER_CONTROL_DATA_FREE_FAIL_GB", "8")) * GIB
REPO_SIZE_WARN_BYTES = int(os.environ.get("PROMOCASTER_CONTROL_REPO_SIZE_WARN_GB", "5")) * GIB
REPOS_TOTAL_WARN_BYTES = int(os.environ.get("PROMOCASTER_CONTROL_REPOS_TOTAL_WARN_GB", "25")) * GIB
UPLOADS_WARN_BYTES = int(os.environ.get("PROMOCASTER_CONTROL_UPLOADS_WARN_GB", "2")) * GIB
BUILD_WARN_BYTES = int(os.environ.get("PROMOCASTER_CONTROL_BUILD_WARN_GB", "5")) * GIB


class CommandError(RuntimeError):
    pass


@dataclass(slots=True)
class Check:
    section: str
    label: str
    status: str
    detail: str
    hint: str | None = None


def color_enabled(stream) -> bool:
    return bool(getattr(stream, "isatty", lambda: False)()) and os.environ.get("NO_COLOR", "0") != "1"


def tag(label: str, color: str, *, stream=sys.stdout) -> str:
    if color_enabled(stream):
        return f"\033[{color}m[{label}]\033[0m"
    return f"[{label}]"


def print_info(message: str) -> None:
    print(f"{tag('INFO', '36')} {message}")


def print_ok(message: str) -> None:
    print(f"{tag('OK', '32')} {message}")


def print_warn(message: str) -> None:
    print(f"{tag('WARN', '33')} {message}")


def print_error(message: str) -> None:
    print(f"{tag('ERROR', '31', stream=sys.stderr)} {message}", file=sys.stderr)


def print_check(status: str, label: str, detail: str) -> None:
    if status == "ok":
        prefix = tag("OK", "32")
    elif status == "warn":
        prefix = tag("WARN", "33")
    else:
        prefix = tag("ERROR", "31")
    print(f"{prefix} {label}: {detail}")


def run(cmd: list[str], *, check: bool = True, capture: bool = False) -> subprocess.CompletedProcess[str]:
    proc = subprocess.run(cmd, check=False, capture_output=capture, text=True)
    if check and proc.returncode != 0:
        detail = (proc.stderr or proc.stdout or "").strip()
        rendered = " ".join(cmd)
        raise CommandError(f"{rendered}: {detail or f'exited {proc.returncode}'}")
    return proc


def capture(cmd: list[str]) -> str:
    return run(cmd, capture=True).stdout.strip()


def is_root() -> bool:
    return os.geteuid() == 0


def is_git_checkout(path: Path) -> bool:
    try:
        return (path / ".git").exists() and (path / "platter.yml").exists()
    except OSError:
        return False


def resolve_source_root() -> Path | None:
    candidates = [SOURCE_ROOT]
    if SOURCE_ROOT_FILE.exists():
        candidates.append(Path(SOURCE_ROOT_FILE.read_text(encoding="utf-8").strip()))
    for candidate in candidates:
        if candidate == SOURCE_ROOT and is_git_checkout(candidate):
            return candidate.resolve()
    return None


def git_value(root: Path, *args: str) -> str:
    proc = run(["git", "-C", str(root), *args], check=False, capture=True)
    return proc.stdout.strip() if proc.returncode == 0 else ""


def git_clean(root: Path) -> tuple[bool, str]:
    detail = git_value(root, "status", "--short")
    return (detail == "", detail or "clean")


def git_env() -> dict[str, str]:
    return {
        **os.environ,
        "GIT_CONFIG_GLOBAL": str(CONTROL_GIT_CONFIG),
        "GIT_SSH_COMMAND": f"ssh -i {CLIENT_GITHUB_KEY} -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new",
    }


def run_git(cmd: list[str], *, check: bool = True, capture: bool = False) -> subprocess.CompletedProcess[str]:
    proc = subprocess.run(cmd, check=False, capture_output=capture, text=True, env=git_env())
    if check and proc.returncode != 0:
        detail = (proc.stderr or proc.stdout or "").strip()
        raise CommandError(f"{' '.join(cmd)}: {detail or f'exited {proc.returncode}'}")
    return proc


def secure_data_paths() -> None:
    for path, mode in ((DATA_DIR, 0o750), (REPOS_DIR, 0o750), (UPLOADS_DIR, 0o750), (SYNC_DIR, 0o750)):
        path.mkdir(parents=True, exist_ok=True)
        try:
            shutil.chown(path, user=SERVICE_USER, group=SERVICE_USER)
        except (LookupError, PermissionError):
            pass
        path.chmod(mode)
    secure_client_github_key_files()
    CONTROL_GIT_CONFIG.parent.mkdir(parents=True, exist_ok=True)
    CONTROL_GIT_CONFIG.touch(mode=0o640, exist_ok=True)
    try:
        shutil.chown(CONTROL_GIT_CONFIG, user=SERVICE_USER, group=SERVICE_USER)
    except (LookupError, PermissionError):
        pass
    CONTROL_GIT_CONFIG.chmod(0o640)


def chown_tree(path: Path, user: str = SERVICE_USER, group: str = SERVICE_USER) -> None:
    try:
        shutil.chown(path, user=user, group=group)
    except (LookupError, PermissionError):
        return
    for root, dirs, files in os.walk(path, onerror=lambda _exc: None):
        for name in dirs:
            try:
                shutil.chown(Path(root) / name, user=user, group=group)
            except OSError:
                continue
        for name in files:
            try:
                shutil.chown(Path(root) / name, user=user, group=group)
            except OSError:
                continue


def git_safe_directories() -> set[str]:
    proc = run_git(["git", "config", "--global", "--get-all", "safe.directory"], check=False, capture=True)
    if proc.returncode != 0:
        return set()
    return {line.strip() for line in proc.stdout.splitlines() if line.strip()}


def ensure_git_safe_directory(repo_path: Path) -> bool:
    secure_data_paths()
    safe_path = str(repo_path.resolve())
    if safe_path in git_safe_directories():
        return False
    run_git(["git", "config", "--global", "--add", "safe.directory", safe_path])
    try:
        shutil.chown(CONTROL_GIT_CONFIG, user=SERVICE_USER, group=SERVICE_USER)
    except (LookupError, PermissionError):
        pass
    CONTROL_GIT_CONFIG.chmod(0o640)
    return True


def command_exists(name: str) -> bool:
    return shutil.which(name) is not None


def path_mode(path: Path) -> str:
    try:
        return oct(path.stat().st_mode & 0o777)
    except OSError:
        return "missing"


def format_bytes(size: int) -> str:
    units = ("B", "KB", "MB", "GB", "TB")
    value = float(size)
    for unit in units:
        if value < 1024 or unit == units[-1]:
            return f"{value:.1f} {unit}" if unit != "B" else f"{int(value)} B"
        value /= 1024
    return f"{size} B"


def directory_size(path: Path) -> int:
    total = 0
    if not path.exists():
        return 0
    for root, dirs, files in os.walk(path, onerror=lambda _exc: None):
        root_path = Path(root)
        for filename in files:
            try:
                total += (root_path / filename).lstat().st_size
            except OSError:
                continue
    return total


def client_github_key_public_text() -> tuple[bool, str]:
    if not CLIENT_GITHUB_KEY.exists():
        return False, "missing"
    if not command_exists("ssh-keygen"):
        return False, "ssh-keygen missing"
    proc = subprocess.run(["ssh-keygen", "-y", "-f", str(CLIENT_GITHUB_KEY)], check=False, capture_output=True, text=True)
    detail = (proc.stderr or proc.stdout).strip()
    return proc.returncode == 0, detail


def secure_client_github_key_files() -> None:
    SSH_DIR.mkdir(parents=True, exist_ok=True)
    try:
        shutil.chown(SSH_DIR, user=SERVICE_USER, group=SERVICE_USER)
    except (LookupError, PermissionError):
        pass
    SSH_DIR.chmod(0o700)
    if CLIENT_GITHUB_KEY.exists():
        try:
            shutil.chown(CLIENT_GITHUB_KEY, user=SERVICE_USER, group=SERVICE_USER)
        except (LookupError, PermissionError):
            pass
        CLIENT_GITHUB_KEY.chmod(0o600)
    public_key = CLIENT_GITHUB_KEY.with_suffix(CLIENT_GITHUB_KEY.suffix + ".pub")
    if public_key.exists():
        try:
            shutil.chown(public_key, user=SERVICE_USER, group=SERVICE_USER)
        except (LookupError, PermissionError):
            pass
        public_key.chmod(0o644)


def client_github_ssh_auth_detail() -> tuple[str, str]:
    if not CLIENT_GITHUB_KEY.exists():
        return "fail", "missing key"
    if not command_exists("ssh"):
        return "fail", "ssh command missing"
    proc = subprocess.run(
        [
            "ssh",
            "-i",
            str(CLIENT_GITHUB_KEY),
            "-o",
            "IdentitiesOnly=yes",
            "-o",
            "BatchMode=yes",
            "-o",
            "StrictHostKeyChecking=accept-new",
            "-o",
            "ConnectTimeout=8",
            "-T",
            "git@github.com",
        ],
        check=False,
        capture_output=True,
        text=True,
    )
    detail = (proc.stderr or proc.stdout).strip() or f"ssh exited {proc.returncode}"
    if "successfully authenticated" in detail:
        return "ok", detail
    if "Permission denied" in detail:
        return "fail", detail
    return "warn", detail


def generate_client_github_key(*, force: bool = False) -> None:
    if not command_exists("ssh-keygen"):
        raise CommandError("ssh-keygen is required to generate the client GitHub key")
    if CLIENT_GITHUB_KEY.exists() and not force:
        raise CommandError(f"{CLIENT_GITHUB_KEY} already exists; use client-github-key generate --force to replace it")
    SSH_DIR.mkdir(parents=True, exist_ok=True)
    if force:
        CLIENT_GITHUB_KEY.unlink(missing_ok=True)
        CLIENT_GITHUB_KEY.with_suffix(CLIENT_GITHUB_KEY.suffix + ".pub").unlink(missing_ok=True)
    run([
        "ssh-keygen",
        "-t",
        "ed25519",
        "-N",
        "",
        "-C",
        "promocaster-control-client",
        "-f",
        str(CLIENT_GITHUB_KEY),
    ])
    secure_client_github_key_files()


def command_client_github_key(args: argparse.Namespace) -> int:
    if args.key_command == "generate":
        generate_client_github_key(force=args.force)
        ok, public_key = client_github_key_public_text()
        if not ok:
            raise CommandError(public_key)
        print_ok(f"Generated client GitHub key at {CLIENT_GITHUB_KEY}")
        print(public_key)
        return 0

    if args.key_command == "edit":
        SSH_DIR.mkdir(parents=True, exist_ok=True)
        CLIENT_GITHUB_KEY.touch(mode=0o600, exist_ok=True)
        secure_client_github_key_files()
        editor = os.environ.get("EDITOR", "nano")
        return subprocess.run([editor, str(CLIENT_GITHUB_KEY)], check=False).returncode

    if args.key_command == "show-public":
        secure_client_github_key_files()
        ok, public_key = client_github_key_public_text()
        if not ok:
            raise CommandError(public_key)
        print(public_key)
        return 0

    if args.key_command == "test":
        secure_client_github_key_files()
        status, detail = client_github_ssh_auth_detail()
        if status == "ok":
            print_ok(detail)
            return 0
        if status == "warn":
            print_warn(detail)
            return 0
        raise CommandError(detail)

    raise CommandError("unknown client-github-key command")


def load_env(path: Path) -> dict[str, str]:
    values: dict[str, str] = {}
    if not path.exists():
        return values
    for line in path.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        values[key] = value
    return values


def load_clients() -> dict[str, dict[str, str]]:
    candidates = []
    env = load_env(CONFIG_PATH)
    if "PROMOCASTER_CONTROL_CLIENTS_FILE" in env:
        candidates.append(Path(env["PROMOCASTER_CONTROL_CLIENTS_FILE"]))
    candidates.extend([APP_DIR / "client.yml", SOURCE_ROOT / "client.yml", Path.cwd() / "client.yml"])
    clients_file = None
    for candidate in candidates:
        try:
            if candidate.exists():
                clients_file = candidate
                break
        except OSError:
            continue
    if clients_file is None:
        raise CommandError("could not find client.yml")

    clients: dict[str, dict[str, str]] = {}
    current_id = ""
    in_clients = False
    for raw_line in clients_file.read_text(encoding="utf-8").splitlines():
        if not raw_line.strip() or raw_line.lstrip().startswith("#"):
            continue
        if raw_line.strip() == "clients:":
            in_clients = True
            continue
        if not in_clients:
            continue
        if raw_line.startswith("  ") and not raw_line.startswith("    ") and raw_line.strip().endswith(":"):
            current_id = raw_line.strip()[:-1]
            clients[current_id] = {}
            continue
        if current_id and raw_line.startswith("    ") and ":" in raw_line:
            key, value = raw_line.strip().split(":", 1)
            clients[current_id][key] = value.strip().strip('"').strip("'")
    return clients


def client_config(client_id: str) -> dict[str, str]:
    clients = load_clients()
    if client_id not in clients:
        raise CommandError(f"unknown client: {client_id}")
    config = clients[client_id]
    if not config.get("repo"):
        raise CommandError(f"client {client_id} is missing repo in client.yml")
    config.setdefault("branch", "master")
    return config


def repo_checkout_name(repo_url: str) -> str:
    name = repo_url.rstrip("/").rsplit("/", 1)[-1]
    if name.endswith(".git"):
        name = name[:-4]
    return name or "repo"


def client_repo_path(client_id: str, config: dict[str, str] | None = None) -> Path:
    config = config or client_config(client_id)
    return REPOS_DIR / repo_checkout_name(config["repo"])


def sync_status_path(client_id: str) -> Path:
    return SYNC_DIR / f"{client_id}.json"


def write_sync_status(client_id: str, state: str, message: str, **extra) -> None:
    from datetime import datetime, timezone

    SYNC_DIR.mkdir(parents=True, exist_ok=True)
    payload = {
        "client": client_id,
        "state": state,
        "message": message,
        "updated_at": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
        **extra,
    }
    sync_status_path(client_id).write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")


def collect_checks() -> list[Check]:
    checks: list[Check] = []
    env = load_env(CONFIG_PATH)
    web_root = Path(env.get("PROMOCASTER_CONTROL_WEB_ROOT", APP_DIR / "web"))
    clients_file = Path(env.get("PROMOCASTER_CONTROL_CLIENTS_FILE", APP_DIR / "client.yml"))

    checks.append(Check("Runtime", "config file", "ok" if CONFIG_PATH.exists() else "fail", str(CONFIG_PATH), None if CONFIG_PATH.exists() else "install Platter and run platter build promocaster-control"))
    checks.append(Check("Runtime", "app dir", "ok" if APP_DIR.exists() else "fail", str(APP_DIR), None if APP_DIR.exists() else "run platter build promocaster-control"))
    checks.append(Check("Runtime", "web root", "ok" if web_root.exists() else "fail", str(web_root), None if web_root.exists() else "run platter build promocaster-control"))
    checks.append(Check("Runtime", "client file", "ok" if clients_file.exists() else "fail", str(clients_file), None if clients_file.exists() else "restore client.yml and run platter build promocaster-control"))
    for child, path in (("repos", REPOS_DIR), ("uploads", UPLOADS_DIR), ("ssh", SSH_DIR), ("sync", SYNC_DIR)):
        checks.append(Check("Runtime", f"data/{child}", "ok" if path.exists() else "fail", str(path), None if path.exists() else "run platter build promocaster-control"))

    usage_root = DATA_DIR if DATA_DIR.exists() else DATA_DIR.parent
    try:
        disk = shutil.disk_usage(usage_root)
        free_status = "ok"
        free_hint = None
        if disk.free < DATA_FREE_FAIL_BYTES:
            free_status = "fail"
            free_hint = "free disk is critically low for large repo clones and uploads"
        elif disk.free < DATA_FREE_WARN_BYTES:
            free_status = "warn"
            free_hint = "large first clones can be 1.5 GB or more; add disk or prune stale data soon"
        checks.append(Check("Storage", "data free space", free_status, f"{format_bytes(disk.free)} free of {format_bytes(disk.total)} on {usage_root}", free_hint))
    except OSError as exc:
        checks.append(Check("Storage", "data free space", "fail", str(exc), "make sure the data filesystem exists"))

    repos_total = directory_size(REPOS_DIR)
    checks.append(Check("Storage", "repo cache total", "warn" if repos_total > REPOS_TOTAL_WARN_BYTES else "ok", format_bytes(repos_total), "repo cache is growing; review client repo sizes" if repos_total > REPOS_TOTAL_WARN_BYTES else None))
    if REPOS_DIR.exists():
        for repo_path in sorted(path for path in REPOS_DIR.iterdir() if path.is_dir()):
            repo_size = directory_size(repo_path)
            checks.append(Check("Storage", f"repo {repo_path.name}", "warn" if repo_size > REPO_SIZE_WARN_BYTES else "ok", format_bytes(repo_size), "large media repo; make sure VPS disk sizing accounts for this client" if repo_size > REPO_SIZE_WARN_BYTES else None))
            if (repo_path / ".git").exists():
                safe = str(repo_path.resolve()) in git_safe_directories()
                checks.append(Check("Storage", f"repo {repo_path.name} git safe", "ok" if safe else "fail", str(repo_path), None if safe else f"run promocaster-control client-repo sync {repo_path.name}"))
    uploads_size = directory_size(UPLOADS_DIR)
    checks.append(Check("Storage", "upload staging", "warn" if uploads_size > UPLOADS_WARN_BYTES else "ok", format_bytes(uploads_size), "stale staged uploads should be cleaned up" if uploads_size > UPLOADS_WARN_BYTES else None))
    build_size = directory_size(BUILD_DIR)
    checks.append(Check("Storage", "temp builds", "warn" if build_size > BUILD_WARN_BYTES else "ok", format_bytes(build_size), "validation build output should be cleaned up" if build_size > BUILD_WARN_BYTES else None))

    public_ok, public_detail = client_github_key_public_text()
    auth_status, auth_detail = client_github_ssh_auth_detail() if CLIENT_GITHUB_KEY.exists() else ("fail", "missing key")
    key_mode = path_mode(CLIENT_GITHUB_KEY)
    key_mode_ok = key_mode == "0o600"
    checks.append(Check("Client GitHub", "private key", "ok" if CLIENT_GITHUB_KEY.exists() else "fail", str(CLIENT_GITHUB_KEY), None if CLIENT_GITHUB_KEY.exists() else "run promocaster-control client-github-key generate"))
    if CLIENT_GITHUB_KEY.exists():
        checks.append(Check("Client GitHub", "private key mode", "ok" if key_mode_ok else "fail", key_mode, None if key_mode_ok else f"run chmod 600 {CLIENT_GITHUB_KEY}"))
        checks.append(Check("Client GitHub", "public key derive", "ok" if public_ok else "fail", public_detail.splitlines()[0] if public_detail else "empty", None if public_ok else "run promocaster-control client-github-key edit"))
        checks.append(Check("Client GitHub", "github auth", auth_status, auth_detail.splitlines()[0] if auth_detail else "empty", None if auth_status == "ok" else "add the public key to GitHub with access to the client repos"))

    return checks


def print_checks(checks: list[Check]) -> int:
    print()
    print_info("Doctor Report")
    print("=============")
    print(f"Config: {CONFIG_PATH}")
    for section in ("Runtime", "Storage", "Client GitHub"):
        rows = [check for check in checks if check.section == section]
        if not rows:
            continue
        print()
        print(section)
        print("-" * len(section))
        for check in rows:
            print_check(check.status, check.label, check.detail)
            if check.hint and check.status != "ok":
                print(f"       hint: {check.hint}")
    print()
    if any(check.status == "fail" for check in checks):
        print_error("Doctor result: FAIL")
        return 1
    if any(check.status == "warn" for check in checks):
        print_warn("Doctor result: WARN")
        return 0
    print_ok("Doctor result: OK")
    return 0


def command_client_repo(args: argparse.Namespace) -> int:
    if args.client_command == "list":
        print()
        print("Configured Clients")
        print("==================")
        for client_id, config in load_clients().items():
            repo_path = client_repo_path(client_id, config)
            marker = "present" if repo_path.exists() else "missing"
            print(f"{client_id} ({config.get('name', client_id)})")
            print(f"  repo: {config.get('repo', '')}")
            print(f"  branch: {config.get('branch', 'master')}")
            print(f"  checkout: {repo_path}")
            print(f"  status: {marker}")
        return 0

    config = client_config(args.client)
    repo_path = client_repo_path(args.client, config)
    branch = config.get("branch", "master")

    if args.client_command == "status":
        print()
        print(f"Client Repo Status: {args.client}")
        print("=" * (20 + len(args.client)))
        print(f"name: {config.get('name', args.client)}")
        print(f"repo: {config['repo']}")
        print(f"branch: {branch}")
        print(f"checkout: {repo_path}")
        if not repo_path.exists():
            print("state: missing")
            print(f"hint: run promocaster-control client-repo sync {args.client}")
            return 1
        if not (repo_path / ".git").exists():
            raise CommandError(f"checkout path exists but is not a git repo: {repo_path}")
        if is_root():
            chown_tree(repo_path)
            ensure_git_safe_directory(repo_path)
        if not args.no_fetch:
            run_git(["git", "-C", str(repo_path), "fetch", "origin", branch])
        local_head = git_value(repo_path, "rev-parse", "--short", "HEAD")
        remote_head = git_value(repo_path, "rev-parse", "--short", f"origin/{branch}")
        current_branch = git_value(repo_path, "branch", "--show-current") or "detached"
        remote_url = git_value(repo_path, "remote", "get-url", "origin")
        clean, clean_detail = git_clean(repo_path)
        ahead_behind = git_value(repo_path, "rev-list", "--left-right", "--count", f"HEAD...origin/{branch}")
        ahead = behind = "?"
        if ahead_behind:
            parts = ahead_behind.split()
            if len(parts) == 2:
                ahead, behind = parts
        in_sync = local_head == remote_head and clean and current_branch == branch
        print(f"state: {'in sync' if in_sync else 'needs attention'}")
        print(f"current branch: {current_branch}")
        print(f"origin: {remote_url}")
        print(f"local HEAD: {local_head}")
        print(f"remote HEAD: {remote_head}")
        print(f"ahead/behind: {ahead} ahead, {behind} behind")
        print(f"working tree: {'clean' if clean else 'dirty'}")
        if not clean:
            print("changes:")
            for line in clean_detail.splitlines():
                print(f"  {line}")
        status_path = sync_status_path(args.client)
        if status_path.exists():
            print(f"sync status: {status_path}")
        if in_sync:
            return 0
        print(f"hint: run promocaster-control client-repo sync {args.client} after resolving any local changes")
        return 1

    if args.client_command == "sync":
        if not CLIENT_GITHUB_KEY.exists():
            raise CommandError(f"missing client GitHub key: {CLIENT_GITHUB_KEY}")
        REPOS_DIR.mkdir(parents=True, exist_ok=True)
        write_sync_status(args.client, "syncing", "starting repo sync", repo_path=str(repo_path), branch=branch)
        try:
            if repo_path.exists():
                chown_tree(repo_path)
                ensure_git_safe_directory(repo_path)
                write_sync_status(args.client, "fetching", "fetching latest changes", repo_path=str(repo_path), branch=branch)
                run_git(["git", "-C", str(repo_path), "fetch", "origin", branch])
                clean, detail = git_clean(repo_path)
                if not clean:
                    raise CommandError(f"client repo checkout is not clean:\n{detail}")
                write_sync_status(args.client, "resetting", "resetting checkout to origin", repo_path=str(repo_path), branch=branch)
                run_git(["git", "-C", str(repo_path), "checkout", branch])
                run_git(["git", "-C", str(repo_path), "reset", "--hard", f"origin/{branch}"])
            else:
                write_sync_status(args.client, "cloning", "cloning repo; first sync may take a while", repo_path=str(repo_path), branch=branch)
                run_git(["git", "clone", "--branch", branch, "--single-branch", config["repo"], str(repo_path)])
            chown_tree(repo_path)
            ensure_git_safe_directory(repo_path)
            head = git_value(repo_path, "rev-parse", "--short", "HEAD")
            size = format_bytes(directory_size(repo_path))
            write_sync_status(args.client, "ready", "repo sync complete", repo_path=str(repo_path), branch=branch, head=head, size=size)
        except Exception as exc:
            write_sync_status(args.client, "error", str(exc), repo_path=str(repo_path), branch=branch)
            raise
        print_ok(f"Synced {args.client} to {repo_path}")
        print(f"     branch: {branch}")
        print(f"     head: {git_value(repo_path, 'rev-parse', '--short', 'HEAD')}")
        print(f"     size: {format_bytes(directory_size(repo_path))}")
        return 0

    raise CommandError("unknown client-repo command")


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(prog="promocaster-control")
    sub = parser.add_subparsers(dest="command", required=True)
    sub.add_parser("doctor", help="Check config, storage, client GitHub key, and client repo health")
    client_key = sub.add_parser("client-github-key", help="Manage Promocaster Control's client repo GitHub key")
    client_key_sub = client_key.add_subparsers(dest="key_command", required=True)
    client_key_generate = client_key_sub.add_parser("generate", help="Generate a new client repo GitHub key")
    client_key_generate.add_argument("--force", action="store_true", help="Replace an existing client GitHub key")
    client_key_sub.add_parser("edit", help="Open the client repo private key in nano or $EDITOR")
    client_key_sub.add_parser("show-public", help="Print the public key derived from the client repo private key")
    client_key_sub.add_parser("test", help="Test client repo SSH authentication to git@github.com")
    client_repo = sub.add_parser("client-repo", help="Sync and inspect configured client repos")
    client_sub = client_repo.add_subparsers(dest="client_command", required=True)
    client_sub.add_parser("list", help="List clients from client.yml")
    client_sync = client_sub.add_parser("sync", help="Clone or fetch a configured client repo")
    client_sync.add_argument("client", help="Client id from client.yml")
    client_status = client_sub.add_parser("status", help="Show local vs remote sync status for a client repo")
    client_status.add_argument("client", help="Client id from client.yml")
    client_status.add_argument("--no-fetch", action="store_true", help="Do not fetch origin before comparing local and remote")
    args = parser.parse_args(argv)

    try:
        if args.command == "doctor":
            return print_checks(collect_checks())
        if args.command == "client-github-key":
            return command_client_github_key(args)
        if args.command == "client-repo":
            return command_client_repo(args)
    except CommandError as exc:
        print_error(str(exc))
        return 1
    return 1


if __name__ == "__main__":
    raise SystemExit(main())
